generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

/// A reusable conversation scenario with two agent configurations.
model Scenario {
  id          String   @id @default(cuid())
  /// URL-friendly key for built-in scenarios (e.g. "sales", "support").
  /// NULL for user-created scenarios.
  slug        String?  @unique
  title       String
  description String?
  /// Whether this is a built-in (shipped with app) scenario.
  builtIn     Boolean  @default(false) @map("built_in")
  /// JSON array of two agent configs: [{ name, role, voice_id, goes_first, prompt }]
  agents      Json
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@map("scenarios")
}

/// Tracks active Pipecat Cloud sessions so /api/stop can terminate them.
model Session {
  id            String   @id @default(cuid())
  roomName      String   @map("room_name")
  roomUrl       String   @map("room_url")
  /// PCC session IDs for each agent in the room.
  agentSessions String[] @map("agent_sessions")
  createdAt     DateTime @default(now()) @map("created_at")

  @@index([roomName])
  @@map("sessions")
}

/// Saved conversation transcript for replay + KPI classification.
model Conversation {
  id         String   @id @default(cuid())
  title      String
  agentNames String[] @map("agent_names")
  /// [{ speaker, text }]
  lines      Json
  /// Daily room URL for this conversation
  roomUrl        String?  @map("room_url")
  /// Per-turn latency metrics: [{ agent, turn, ttfb, llm, tts, e2e }]
  latencyMetrics Json?    @map("latency_metrics")
  /// Pinecone vector ID for embedded transcript
  embeddingId String?  @map("embedding_id")
  /// JSON: { resolution, sentiment, efficiency, ... }
  kpiScores   Json?    @map("kpi_scores")
  /// Overall outcome label from KPI classification
  outcome     String?
  /// Live summary generated during the conversation
  summary     String?
  createdAt   DateTime @default(now()) @map("created_at")

  @@map("conversations")
}

/// Per-session latency metrics reported by Pipecat agents.
model SessionMetric {
  id          String   @id @default(cuid())
  sessionId   String   @map("session_id")
  agentName   String   @map("agent_name")
  /// Time to first byte from LLM (ms)
  ttfb        Float?
  /// LLM processing duration (ms)
  llmDuration Float?   @map("llm_duration")
  /// TTS processing duration (ms)
  ttsDuration Float?   @map("tts_duration")
  /// End-to-end latency: user speech end → audio playback start (ms)
  e2eLatency  Float?   @map("e2e_latency")
  /// User-to-bot latency: VAD user stopped speaking → bot started speaking (ms)
  userBotLatency Float? @map("user_bot_latency")
  /// LLM token usage: { prompt_tokens, completion_tokens }
  tokenUsage  Json?    @map("token_usage")
  /// Turn index within the session
  turnIndex   Int      @default(0) @map("turn_index")
  createdAt   DateTime @default(now()) @map("created_at")

  @@index([sessionId])
  @@index([createdAt])
  @@map("session_metrics")
}
